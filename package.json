{
  "name": "crunchy-deck",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:web": "vite dev --port 5173",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.node.json && node scripts/postbuild-electron.mjs",
    "dev": "concurrently -k \"pnpm dev:web\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "pnpm build:web && pnpm build:electron",
    "build:app": "pnpm build:web && pnpm build:electron && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^24.13.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "https://github.com/castlabs/electron-releases#v40.7.0+wvcus",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource/geist-mono": "^5.2.8",
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4",
    "shaka-player": "4.16.38"
  },
  "build": {
    "appId": "app.crunchydeck",
    "productName": "Crunchy Deck",
    "artifactName": "${name}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "nicholasyoannou",
        "repo": "crunchy-deck"
      }
    ],
    "asar": false,
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "files": [
      "dist-electron/**",
      "build/**"
    ],
    "afterPack": "scripts/vmp-sign.cjs",
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "license": "GPL-3.0-or-later"
}
